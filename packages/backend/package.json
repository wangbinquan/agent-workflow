{
  "name": "@agent-workflow/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "agent-workflow": "src/main.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts start",
    "start": "bun run src/main.ts start",
    "build": "echo 'use scripts/build-binary.ts (M5)'",
    "lint": "eslint src tests --max-warnings=0",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@agent-workflow/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "ulid": "^2.3.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0"
  }
}
