{
  "name": "agent-workflow",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first orchestration platform that drives multiple opencode CLI processes as collaborating agents",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint && bun run lint:repo-ui",
    "lint:repo-ui": "eslint playwright.config.ts \"e2e/**/*.ts\" --max-warnings=0",
    "lint:fix": "bun run --filter '*' lint:fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\" && bun run format:check:repo-ui",
    "format:check:repo-ui": "prettier --check package.json playwright.config.ts \"e2e/**/*.{ts,md}\" \".github/workflows/*.{yml,yaml}\"",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run test:backend && bun run test:shared && bun run test:frontend",
    "test:backend": "bun test --isolate --randomize",
    "test:shared": "bun run --filter @agent-workflow/shared test",
    "test:frontend": "bun run --filter @agent-workflow/frontend test",
    "build:binary": "bun run scripts/build-binary.ts",
    "e2e": "playwright test",
    "test:visual": "RUN_VISUAL_REGRESSION=1 playwright test e2e/visual-regression.spec.ts --project=chromium",
    "e2e:install": "playwright install --with-deps chromium",
    "record:opencode": "bun run scripts/record-opencode.ts",
    "depcheck": "depcruise --config .dependency-cruiser.cjs packages/frontend/src packages/backend/src packages/shared/src"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.0",
    "@types/bun": "latest",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fflate": "^0.8.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "overrides": {
    "fast-uri": "3.1.3",
    "hono": "4.12.26",
    "vite": "6.4.3",
    "ws": "8.21.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
